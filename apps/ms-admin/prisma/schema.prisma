generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "complaints", "status"]
}

// ==============================================
// SCHEMA: public (Auth Tables)
// Required to register Analysts
// ==============================================

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String     @map("password_hash")
  createdAt     DateTime   @default(now()) @map("created_at")
  
  userRoles     UserRole[]
  
  @@map("users")
  @@schema("public")
}

model Role {
  id        String     @id @default(uuid())
  name      String     @unique
  userRoles UserRole[]

  @@map("roles")
  @@schema("public")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("public")
}

// ==============================================
// SCHEMA: complaints (Complaint Tables)
// Required to List/Query
// ==============================================

model Complaint {
  id          String   @id @default(uuid())
  aliasToken  String   @unique
  payload     Json     
  status      String   @default("RECEIVED") 
  createdAt   DateTime @default(now())

  @@schema("complaints")
}

// ==============================================
// SCHEMA: status (Case Statuses)
// Required to get the true status of complaints
// ==============================================

model CaseStatus {
  id          String   @id @default(uuid())
  complaintId String   @unique @map("complaint_id")
  status      String   @default("SUBMITTED")
  urgency     String   @default("LOW")
  assignedTo  String?  @map("assigned_to")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("case_statuses")
  @@schema("status")
}
