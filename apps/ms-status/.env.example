# PostgreSQL (schema=status on EC2-6)
# Shares the same database instance as ms-auth and ms-submission
DATABASE_URL=postgresql://anonygate:anonygate_pass@localhost:5432/anonygate_db?schema=status

# Kafka (on EC2-8)
KAFKA_BROKER=localhost:9092

# RabbitMQ (on EC2-8)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Redis for WebSocket Sessions (on EC2-8)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=anonygate_pass

# MQTT Broker for Mobile Alerts (on EC2-8 or External)
MQTT_BROKER_URL=mqtt://localhost:1883

# JWT Secret (Must match the one in ms-auth to validate Analyst/Admin tokens)
JWT_SECRET=your-jwt-secret-here

# Port
PORT=3006
